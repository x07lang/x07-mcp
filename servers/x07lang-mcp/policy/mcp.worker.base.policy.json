{
  "schema_version": "x07.run-os-policy@0.1.0",
  "policy_id": "mcp.worker.base",
  "notes": "Base policy for MCP tool workers. No fs/net/env by default. Allows bounded sleep for backoff.",
  "limits": {
    "cpu_ms": 300000,
    "wall_ms": 300000,
    "mem_bytes": 1073741824,
    "fds": 64,
    "procs": 16,
    "core_dumps": false
  },
  "fs": {
    "enabled": true,
    "read_roots": [
      ".",
      "/Users/",
      "/home/",
      "/tmp/",
      "/private/tmp/",
      "/var/folders/",
      "/usr/local/",
      "/opt/homebrew/",
      "/usr/bin/",
      "/usr/lib/",
      "/bin/",
      "/System/",
      "/Library/"
    ],
    "write_roots": [],
    "deny_hidden": false,
    "allow_symlinks": false,
    "allow_mkdir": true,
    "allow_remove": true,
    "allow_rename": true,
    "allow_walk": true,
    "allow_glob": true,
    "max_read_bytes": 33554432,
    "max_write_bytes": 33554432,
    "max_entries": 20000,
    "max_depth": 128
  },
  "net": {
    "enabled": false,
    "allow_dns": false,
    "allow_tcp": false,
    "allow_udp": false,
    "allow_hosts": []
  },
  "env": {
    "enabled": true,
    "allow_keys": [
      "HOME",
      "PATH",
      "XDG_CACHE_HOME",
      "X07UP_HOME",
      "X07_MCP_X07_EXE",
      "X07_MCP_X07_WASM_EXE",
      "X07_MCP_X07LP_EXE",
      "X07_MCP_X07_DEVICE_HOST_DESKTOP_EXE"
    ],
    "deny_keys": []
  },
  "time": {
    "enabled": true,
    "allow_monotonic": true,
    "allow_wall_clock": false,
    "allow_sleep": true,
    "max_sleep_ms": 5000,
    "allow_local_tzid": false
  },
  "language": {
    "allow_unsafe": true,
    "allow_ffi": true
  },
  "threads": {
    "enabled": true,
    "max_workers": 0,
    "max_blocking": 4,
    "max_queue": 1024
  },
  "process": {
    "enabled": true,
    "allow_spawn": true,
    "max_live": 4,
    "max_spawns": 32,
    "allow_exec": true,
    "allow_exit": true,
    "allow_execs": [],
    "allow_exec_prefixes": [
      "/Users/",
      "/home/",
      "/opt/homebrew/bin/",
      "/usr/local/bin/",
      "/tmp/",
      "/private/tmp/",
      "/var/folders/",
      "/usr/bin/"
    ],
    "allow_args_regex_lite": [],
    "allow_env_keys": [
      "HOME",
      "PATH",
      "XDG_CACHE_HOME",
      "X07UP_HOME",
      "X07_MCP_X07_EXE",
      "X07_MCP_X07_WASM_EXE",
      "X07_MCP_X07LP_EXE",
      "X07_MCP_X07_DEVICE_HOST_DESKTOP_EXE",
      "X07_OS_FS",
      "X07_OS_FS_READ_ROOTS",
      "X07_OS_FS_WRITE_ROOTS",
      "X07_OS_NET",
      "X07_OS_NET_ALLOW_TCP",
      "X07_OS_NET_ALLOW_DNS",
      "X07_OS_NET_ALLOW_HOSTS",
      "X07_OS_PROC",
      "X07_OS_PROC_ALLOW_EXIT",
      "X07_OS_PROC_ALLOW_SPAWN",
      "X07_OS_PROC_ALLOW_EXEC",
      "X07_OS_PROC_ALLOW_CWD",
      "X07_OS_PROC_KILL_ON_DROP",
      "X07_OS_PROC_KILL_TREE",
      "X07_OS_PROC_ALLOW_EXECS",
      "X07_OS_PROC_ALLOW_EXEC_PREFIXES",
      "X07_OS_PROC_ALLOW_ARGS_REGEX_LITE",
      "X07_OS_PROC_ALLOW_ENV_KEYS",
      "X07_OS_PROC_ALLOW_CWD_ROOTS",
      "X07_OS_PROC_MAX_LIVE",
      "X07_OS_PROC_MAX_SPAWNS",
      "X07_OS_PROC_MAX_EXE_BYTES",
      "X07_OS_PROC_MAX_ARGS",
      "X07_OS_PROC_MAX_ARG_BYTES",
      "X07_OS_PROC_MAX_ENV",
      "X07_OS_PROC_MAX_ENV_KEY_BYTES",
      "X07_OS_PROC_MAX_ENV_VAL_BYTES",
      "X07_OS_PROC_MAX_RUNTIME_MS",
      "X07_OS_PROC_MAX_STDOUT_BYTES",
      "X07_OS_PROC_MAX_STDERR_BYTES",
      "X07_OS_PROC_MAX_TOTAL_BYTES",
      "X07_OS_PROC_MAX_STDIN_BYTES",
      "X07_OS_ENV",
      "X07_OS_ENV_ALLOW_KEYS"
    ],
    "max_exe_bytes": 4096,
    "max_args": 64,
    "max_arg_bytes": 4096,
    "max_env": 64,
    "max_env_key_bytes": 256,
    "max_env_val_bytes": 4096,
    "max_runtime_ms": 300000,
    "max_stdout_bytes": 262144,
    "max_stderr_bytes": 262144,
    "max_total_bytes": 524288,
    "max_stdin_bytes": 16384,
    "kill_on_drop": true,
    "kill_tree": true,
    "allow_cwd": true,
    "allow_cwd_roots": [
      ".",
      "/Users/",
      "/home/",
      "/tmp/",
      "/private/tmp/",
      "/var/folders/"
    ]
  }
}
