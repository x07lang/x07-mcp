{
  "schema_version": "x07.mcp.rr.http_session@0.1.0",
  "id": "golden.prm_signed_200",
  "profile": "prod",
  "project_files": {
    "server": "config/mcp.server.oauth.prm_signed.json",
    "tools": "config/mcp.tools.json",
    "oauth": "config/mcp.oauth.prm_signed.json",
    "resources": "config/mcp.resources.json",
    "prompts": "config/mcp.prompts.json"
  },
  "base_url": "http://127.0.0.1:8314",
  "mcp_path": "/mcp",
  "steps": [
    {
      "name": "prm_insertion_returns_200_with_signed_metadata",
      "req": {
        "method": "GET",
        "path": "/.well-known/oauth-protected-resource/mcp",
        "headers": {
          "Origin": "http://localhost:3000",
          "Accept": "application/json, text/event-stream"
        }
      },
      "res": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body_json_has_keys": [
          "signed_metadata"
        ]
      }
    }
  ]
}
