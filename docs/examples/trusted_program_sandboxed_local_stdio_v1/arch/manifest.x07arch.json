{
  "schema_version": "x07.arch.manifest@0.3.0",
  "repo": { "id": "trusted_program_sandboxed_local_stdio_v1", "root": "." },
  "externals": {
    "allowed_import_prefixes": [],
    "allowed_exact": [
      "ext.data_model",
      "ext.json.data_model",
      "std.bytes",
      "std.fs",
      "std.mcp.diag",
      "std.mcp.sandbox.worker_main",
      "std.mcp.sandbox.worker_proto",
      "std.mcp.tool.result",
      "std.mcp.transport.stdio",
      "std.os.env",
      "std.os.stdio",
      "std.os.stdio.spec",
      "std.test"
    ]
  },
  "nodes": [
    {
      "id": "router_untrusted",
      "match": {
        "module_prefixes": ["main", "router", "certify", "trusted_stdio"],
        "path_globs": [
          "src/main.x07.json",
          "src/router.x07.json",
          "src/certify.x07.json",
          "src/trusted_stdio.x07.json"
        ]
      },
      "world": "run-os-sandboxed",
      "trust_zone": "untrusted",
      "visibility": { "mode": "public", "visible_to": [] },
      "imports": {
        "deny_prefixes": ["tests.", "capsule_smoke."],
        "allow_prefixes": ["main", "router", "certify", "trusted_stdio", "worker", "std.", "ext."]
      }
    },
    {
      "id": "worker_capsule",
      "match": {
        "module_prefixes": ["worker", "mcp.user"],
        "path_globs": ["src/worker.x07.json", "src/worker_main.x07.json", "src/mcp/**/*.x07.json"]
      },
      "world": "run-os-sandboxed",
      "trust_zone": "certified_capsule",
      "visibility": {
        "mode": "restricted",
        "visible_to": ["router_untrusted", "tests_capsule", "worker_capsule"]
      },
      "imports": {
        "deny_prefixes": ["router.", "tests.", "smoke."],
        "allow_prefixes": ["worker", "mcp.user", "std.", "ext."]
      }
    },
    {
      "id": "tests_smoke",
      "match": {
        "module_prefixes": ["smoke"],
        "path_globs": ["tests/smoke.x07.json"]
      },
      "world": "run-os-sandboxed",
      "trust_zone": "test_only",
      "visibility": { "mode": "restricted", "visible_to": [] },
      "imports": {
        "deny_prefixes": ["std.os."],
        "allow_prefixes": ["smoke", "std.", "ext."]
      }
    },
    {
      "id": "tests_capsule",
      "match": {
        "module_prefixes": ["capsule_smoke"],
        "path_globs": ["tests/capsule_smoke.x07.json"]
      },
      "world": "run-os-sandboxed",
      "trust_zone": "test_only",
      "visibility": { "mode": "restricted", "visible_to": [] },
      "imports": {
        "deny_prefixes": [],
        "allow_prefixes": ["capsule_smoke", "trusted_stdio", "worker", "std.", "ext."]
      }
    }
  ],
  "rules": [
    {
      "kind": "layers_v1",
      "id": "layers.main_v1",
      "layers": ["router_untrusted", "worker_capsule", "tests_smoke", "tests_capsule"],
      "direction": "down"
    },
    { "kind": "deny_cycles_v1", "id": "deny_cycles.nodes_v1", "scope": "nodes" }
  ],
  "checks": {
    "deny_cycles": true,
    "deny_orphans": true,
    "enforce_visibility": true,
    "enforce_world_caps": true,
    "brand_boundary_v1": { "enabled": true },
    "world_of_imported_v1": { "enabled": true },
    "allowlist_mode": {
      "enabled": true,
      "default_allow_external": false,
      "default_allow_internal": false
    }
  },
  "tool_budgets": {
    "max_modules": 5000,
    "max_edges": 50000,
    "max_diags": 2000,
    "contracts_budgets": { "max_contract_files": 2000, "max_contract_bytes": 67108864 }
  },
  "contracts_v1": {
    "boundaries": {
      "index_path": "arch/boundaries/index.x07boundary.json",
      "enforce": "error"
    },
    "rr": {
      "index_path": "arch/rr/index.x07rr.json",
      "gen_dir": "arch/rr",
      "require_policy_for_os_calls": false
    },
    "budgets": {
      "index_path": "arch/budgets/index.x07budgets.json",
      "gen_dir": "arch/budgets/gen",
      "require_scopes": false
    },
    "canonical_json": { "mode": "jcs_rfc8785_v1" }
  }
}
