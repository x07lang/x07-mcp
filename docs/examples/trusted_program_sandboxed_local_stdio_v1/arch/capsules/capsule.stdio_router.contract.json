{
  "schema_version": "x07.capsule.contract@0.2.0",
  "id": "capsule.stdio_router_v1",
  "worlds_allowed": ["run-os-sandboxed"],
  "capabilities": [],
  "language": {
    "allow_unsafe": true,
    "allow_ffi": true
  },
  "input": {
    "shape": {
      "brand": "trusted_stdio.router_start_v1"
    }
  },
  "output": {
    "shape": {
      "brand": "trusted_stdio.router_status_v1"
    }
  },
  "error_spaces": ["trusted_stdio.router_error_v1"],
  "effect_log": {
    "schema_path": "capsule.stdio_router.effect_log.json",
    "redaction": "metadata_only",
    "replay_safe": true
  },
  "replay": {
    "mode": "deterministic"
  },
  "conformance": {
    "tests": ["smoke/router_contract", "bundle/stdio_smoke"],
    "report_path": "capsule.stdio_router.conformance.json"
  }
}
