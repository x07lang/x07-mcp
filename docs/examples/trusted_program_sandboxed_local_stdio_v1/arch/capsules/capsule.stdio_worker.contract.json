{
  "schema_version": "x07.capsule.contract@0.1.0",
  "id": "capsule.stdio_worker_v1",
  "worlds_allowed": ["run-os-sandboxed"],
  "capabilities": [],
  "language": {
    "allow_unsafe": false,
    "allow_ffi": false
  },
  "input": {
    "shape": {
      "brand": "trusted_stdio.worker_request_v1"
    }
  },
  "output": {
    "shape": {
      "brand": "trusted_stdio.worker_response_v1"
    }
  },
  "error_spaces": ["trusted_stdio.worker_error_v1"],
  "effect_log": {
    "schema_path": "capsule.stdio_worker.effect_log.json",
    "redaction": "metadata_only",
    "replay_safe": true
  },
  "replay": {
    "mode": "deterministic"
  },
  "conformance": {
    "tests": ["capsule/worker_echo", "sandbox/worker_echo_attested"],
    "report_path": "capsule.stdio_worker.conformance.json"
  }
}
