{
  "schema_version": "x07.run-os-policy@0.1.0",
  "policy_id": "mcp.router.base",
  "notes": "Base policy for the certified HTTP router. Reads project tree, writes under out/, and binds only the loopback MCP listener.",
  "limits": {
    "cpu_ms": 60000,
    "wall_ms": 120000,
    "mem_bytes": 536870912,
    "fds": 128,
    "procs": 32,
    "core_dumps": false
  },
  "fs": {
    "enabled": true,
    "read_roots": ["."],
    "write_roots": ["out"],
    "deny_hidden": true,
    "allow_symlinks": false,
    "allow_mkdir": true,
    "allow_remove": false,
    "allow_rename": true,
    "allow_walk": true,
    "allow_glob": true,
    "max_read_bytes": 67108864,
    "max_write_bytes": 67108864,
    "max_entries": 50000,
    "max_depth": 64
  },
  "net": {
    "enabled": true,
    "allow_dns": false,
    "allow_tcp": true,
    "allow_udp": false,
    "allow_hosts": [
      {
        "host": "127.0.0.1",
        "ports": [8314]
      }
    ]
  },
  "env": { "enabled": false, "allow_keys": [], "deny_keys": [] },
  "time": {
    "enabled": true,
    "allow_monotonic": true,
    "allow_wall_clock": true,
    "allow_sleep": false,
    "max_sleep_ms": 0,
    "allow_local_tzid": false
  },
  "language": { "allow_unsafe": true, "allow_ffi": true },
  "threads": { "enabled": true, "max_workers": 0, "max_blocking": 4, "max_queue": 1024 },
  "process": {
    "enabled": true,
    "allow_spawn": true,
    "max_live": 16,
    "max_spawns": 64,
    "allow_exec": true,
    "allow_exit": true,
    "allow_execs": [],
    "allow_exec_prefixes": ["out/"],
    "allow_args_regex_lite": [],
    "allow_env_keys": [],
    "max_exe_bytes": 4096,
    "max_args": 64,
    "max_arg_bytes": 4096,
    "max_env": 128,
    "max_env_key_bytes": 256,
    "max_env_val_bytes": 4096,
    "max_runtime_ms": 120000,
    "max_stdout_bytes": 10485760,
    "max_stderr_bytes": 10485760,
    "max_total_bytes": 16777216,
    "max_stdin_bytes": 1048576,
    "kill_on_drop": true,
    "kill_tree": true,
    "allow_cwd": false,
    "allow_cwd_roots": []
  }
}
