{
  "schema_version": "x07.capsule.contract@0.2.0",
  "id": "capsule.http_router_v1",
  "worlds_allowed": ["run-os-sandboxed"],
  "capabilities": [],
  "language": {
    "allow_unsafe": true,
    "allow_ffi": true
  },
  "input": {
    "shape": {
      "brand": "trusted_mcp.router_start_v1"
    }
  },
  "output": {
    "shape": {
      "brand": "trusted_mcp.router_status_v1"
    }
  },
  "error_spaces": ["trusted_mcp.router_error_v1"],
  "effect_log": {
    "schema_path": "capsule.http_router.effect_log.json",
    "redaction": "metadata_only",
    "replay_safe": true
  },
  "replay": {
    "mode": "deterministic"
  },
  "conformance": {
    "tests": ["smoke/router_contract", "smoke/http_echo"],
    "report_path": "capsule.http_router.conformance.json"
  },
  "network": {
    "peer_policy_paths": ["peers/loopback_http_v1.peer.json"],
    "request_contract_path": null,
    "response_contract_path": null,
    "conformance_tests": ["smoke/http_echo"]
  }
}
