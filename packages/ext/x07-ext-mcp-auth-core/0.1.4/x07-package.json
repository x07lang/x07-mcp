{
  "schema_version": "x07.package@0.1.0",
  "name": "ext-mcp-auth-core",
  "version": "0.1.4",
  "description": "MCP auth core helpers: deterministic RFC9728 PRM URLs/docs, Bearer+DPoP header parsing, WWW-Authenticate challenges, and scope utilities.",
  "docs": "MCP auth core helpers.\n\nModules:\n- std.mcp.auth.prm_v1\n- std.mcp.auth.bearer_v1\n- std.mcp.auth.scopes_v1\n",
  "module_root": "modules",
  "modules": [
    "std.mcp.auth.prm_v1",
    "std.mcp.auth.bearer_v1",
    "std.mcp.auth.scopes_v1"
  ],
  "meta": {
    "determinism_tier": "pure",
    "worlds_allowed": [
      "solve-pure",
      "solve-fs",
      "solve-rr",
      "solve-kv",
      "solve-full",
      "run-os",
      "run-os-sandboxed"
    ],
    "requires_packages": [
      "ext-data-model@>=0.1.11 <0.2.0",
      "ext-json-rs@>=0.1.7 <0.2.0",
      "ext-url-rs@>=0.1.5 <0.2.0"
    ],
    "import_mode": "handwritten",
    "x07c_compat": ">=0.1.111 <0.3.0"
  },
  "license": "MIT OR Apache-2.0"
}
