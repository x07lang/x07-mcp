    "std.mcp.toolkit.resources_file",
    "std.mcp.toolkit.prompts_file",
    "std.mcp.toolkit.tools_file",
    "std.mcp.toolkit.server_cfg_file",
    "std.mcp.toolkit.schema_subset",
    "std.mcp.toolkit.derive_hooks",
    "std.mcp.toolkit.stdio_dispatch",
    "std.mcp.toolkit.jsonl_stdout",
