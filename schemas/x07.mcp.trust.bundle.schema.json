{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07.mcp.trust.bundle.schema.json",
  "title": "x07.mcp.trust.bundle@0.1.0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "bundle_id",
    "version",
    "issuers"
  ],
  "properties": {
    "schema_version": {
      "const": "x07.mcp.trust.bundle@0.1.0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "issuers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "issuer",
          "algs",
          "jwks"
        ],
        "properties": {
          "issuer": {
            "type": "string",
            "pattern": "^https://[^#]+$"
          },
          "usage": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "algs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "jwks": {
            "type": "object",
            "required": [
              "keys"
            ],
            "properties": {
              "keys": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": [
                    "kty",
                    "kid"
                  ],
                  "properties": {
                    "kty": {
                      "type": "string",
                      "enum": [
                        "OKP",
                        "RSA"
                      ]
                    },
                    "kid": {
                      "type": "string",
                      "minLength": 1
                    },
                    "crv": {
                      "type": "string"
                    },
                    "x": {
                      "type": "string"
                    },
                    "n": {
                      "type": "string"
                    },
                    "e": {
                      "type": "string"
                    }
                  },
                  "allOf": [
                    {
                      "if": {
                        "properties": {
                          "kty": {
                            "const": "OKP"
                          }
                        }
                      },
                      "then": {
                        "required": [
                          "crv",
                          "x"
                        ]
                      }
                    },
                    {
                      "if": {
                        "properties": {
                          "kty": {
                            "const": "RSA"
                          }
                        }
                      },
                      "then": {
                        "required": [
                          "n",
                          "e"
                        ]
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
