{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07.mcp.trust.framework.schema.json",
  "title": "x07.mcp.trust.framework@0.2.0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "framework_id",
    "bundle_publishers",
    "bundles",
    "resources"
  ],
  "properties": {
    "schema_version": {
      "const": "x07.mcp.trust.framework@0.2.0"
    },
    "framework_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "bundle_publishers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "issuer",
          "jwks"
        ],
        "properties": {
          "issuer": {
            "type": "string",
            "pattern": "^https://[^#]+$"
          },
          "jwks": {
            "type": "object",
            "required": [
              "keys"
            ],
            "properties": {
              "keys": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "kty",
                    "kid"
                  ]
                }
              }
            }
          },
          "accepted_algs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "max_ttl_secs": {
            "type": "integer",
            "minimum": 0
          },
          "clock_skew_secs": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sig_jwt_path": {
            "type": "string",
            "minLength": 1
          },
          "publisher_issuer": {
            "type": "string",
            "pattern": "^https://[^#]+$"
          },
          "require_signature": {
            "type": "boolean"
          },
          "expected_bundle_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "expected_sig_jwt_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "resource",
          "authorization_server_policy"
        ],
        "properties": {
          "resource": {
            "type": "string",
            "pattern": "^https://[^#]+$"
          },
          "authorization_server_policy": {
            "type": "object",
            "required": [
              "strategy",
              "allowed_issuers",
              "mode"
            ],
            "properties": {
              "strategy": {
                "type": "string",
                "enum": [
                  "prefer_order_v1"
                ]
              },
              "allowed_issuers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^https://[^#]+$"
                }
              },
              "prefer_issuers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^https://[^#]+$"
                }
              },
              "require_https": {
                "type": "boolean"
              },
              "mode": {
                "type": "string",
                "enum": [
                  "fail_closed",
                  "fail_open"
                ]
              }
            }
          },
          "prm_signed_metadata_policy": {
            "type": "object",
            "properties": {
              "require_signed_metadata": {
                "type": "boolean"
              },
              "allowed_signing_issuers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^https://[^#]+$"
                }
              },
              "mode": {
                "type": "string",
                "enum": [
                  "fail_closed",
                  "best_effort",
                  "fail_open"
                ]
              }
            }
          }
        }
      }
    }
  }
}
